# ====== SERVEUR ======
PORT=3000
NODE_ENV=development

# ====== BASE DE DONNÉES ======
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fiche_technique
DB_USER=postgres
DB_PASSWORD=your_password
# Mettre à true en production (Azure PostgreSQL exige SSL)
DB_SSL=false

# ====== JWT ======
# Générer: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# ====== EMAIL (Resend) ======
# Laisser vide en dev — les liens d'invitation sont loggés dans la console
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# ====== APP ======
# URL du frontend déployé (utilisée pour CORS et les liens email)
APP_URL=http://localhost:5173
APP_NAME=Fiche Technique

# ====== PRODUCTION AZURE (exemples) ======
# DB_HOST=psql-fichetech-prod.postgres.database.azure.com
# DB_SSL=true
# APP_URL=https://swa-fichetech-frontend-prod.azurestaticapps.net
