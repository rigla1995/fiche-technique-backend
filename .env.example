# =========================================================
# LabFlow Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# =========================================================

# ── Serveur ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de données PostgreSQL ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fiche_technique
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe
DB_SSL=false

# ── Authentification JWT ─────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez_moi_en_production

# ── Email (Resend) ───────────────────────────────────────
# Compte gratuit sur resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@votredomaine.com

# ── Application ──────────────────────────────────────────
APP_URL=http://localhost:5173
APP_NAME=LabFlow

# ── Agent IA — Telegram ──────────────────────────────────
# Telegram → @BotFather → /newbot → copier le token
TELEGRAM_BOT_TOKEN=

# ── Agent IA — Claude (Anthropic) — moteur principal ─────
# console.anthropic.com → API Keys → Create
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── Agent IA — Groq (tool-calling natif, llama-3.3-70b) ──
# console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_xxxxxxxxxxxx
# Modèle Groq (optionnel) — défaut llama-3.3-70b-versatile
GROQ_MODEL=

# ── Choix du moteur de l'agent IA ────────────────────────
# 'groq' (défaut si GROQ_API_KEY présent, recommandé : tool-use fiable) | 'claude' (Haiku)
AI_PROVIDER=groq

# ── Agent IA — Messenger (Facebook Page) ─────────────────
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_PAGE_USERNAME=
# App Secret de l'app Meta — ACTIVE la vérification de signature X-Hub-Signature-256
# du webhook Messenger (recommandé). Tant qu'il est vide, le webhook n'est PAS authentifié.
MESSENGER_APP_SECRET=

# ── Contrats Docuseal ────────────────────────────────────
# URL + token suffisent pour le flux « PDF rempli » (contrat généré par client,
# envoyé via l'API templates/pdf). Les TEMPLATE_ID ne servent plus que de REPLI
# si la génération du PDF échoue.
DOCUSEAL_URL=
DOCUSEAL_API_TOKEN=
DOCUSEAL_TEMPLATE_ID=
DOCUSEAL_TEMPLATE_AVENANT_ID=
DOCUSEAL_TEMPLATE_RESILIATION_ID=
# Secret partagé du webhook Docuseal — ACTIVE l'authentification du webhook.
# À définir ici ET dans Docuseal (Webhook → en-tête X-Docuseal-Secret = cette valeur).
# Tant qu'il est vide, le webhook n'est PAS authentifié (n'importe qui peut le forger).
DOCUSEAL_WEBHOOK_SECRET=

# ── Identité légale du prestataire (contrats + factures) ─
# Mentions portées sur les contrats/avenants/résiliations générés (docuseal-templates)
# et le pied des factures. OBLIGATOIRE en prod : tant qu'un placeholder fictif subsiste,
# la génération « PDF rempli » est REFUSÉE en production (repli sur le flux template).
# FACTURE_STRICT : 1 = strict partout ; 0 = désactive le strict même en prod (déconseillé).
FACTURE_PRESTATAIRE_NOM=            # nom commercial, ex. LabFlow (partagé factures/contrats)
FACTURE_ADRESSE=                    # siège social complet (partagé factures/contrats)
FACTURE_MATRICULE_FISCAL=           # matricule fiscal, ex. 1234567/A/M/000
FACTURE_TVA_RATE=19
PRESTATAIRE_FORME=                  # forme juridique, ex. SARL
PRESTATAIRE_RAISON_SOCIALE=         # défaut : "<NOM> <FORME>"
PRESTATAIRE_RC=                     # n° registre national des entreprises (RNE/RC)
PRESTATAIRE_CAPITAL=                # ex. 10 000 DT
PRESTATAIRE_VILLE=                  # lieu de signature, ex. Tunis
PRESTATAIRE_EMAIL=
PRESTATAIRE_TEL=
PRESTATAIRE_SIGNATAIRE=             # ex. M. Prénom Nom, gérant
FACTURE_STRICT=

# ── Tuning du pool PostgreSQL (optionnel) ────────────────
# max ≈ (max_connections Postgres) / (nb d'instances). Défauts: 15 / 30s / 5s / 30s.
DB_POOL_MAX=15
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000

# ── Observabilité (optionnel) ────────────────────────────
# Si défini, branchez Sentry (à installer séparément). Laissé vide = logs structurés JSON seuls.
SENTRY_DSN=
